{
  "manifest_version": 3,
  "name": "Go To Sleep 😴",
  "version": "1.0",
  "description": "Block distracting websites when you should be sleeping.",
  "permissions": ["storage", "tabs", "webNavigation"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Go To Sleep 😴"
  },
  "web_accessible_resources": [
    {
      "resources": ["blocked.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
